<% layout("/layouts/boilerplate")  %>
<div class="row mt-3">
  <div class="col-8 offset-2">
    <br/>

  <h3>Create a new Listing</h3>
  <form method="POST" action="/listings" novalidate class="needs-validation">

  <div class="mb-3">
      <label for="title" class="form-lebel">Title</label>
      <input name="listing[title]" placeholder="enter title" type="text" class="form-control" required/>

  <div class="valid-feedback">Title looks good!</div>
    </div>
  <br/>

  <div class="mb-3">
      <label for="description" class="form-lebel">Description</label>
      <textarea name="listing[description]" 
      class="form-control" required></textarea>
       <div class="invalid-feedback">please enter short description</div>
  </div>
  <br/>
   
  <div class="mb-3">
      <label for="image" class="form-lebel">Image</label>
      <input name="listing[image]" placeholder="enter image" type="text" class="form-control"/>
  </div>
  <br/>
    
  <!-- //price country akta row a asbe -->
  <div class="row">

    <div class="mb-3 col-md-4">
      <label for="price" class="form-lebel">Price</label>
      <input name="listing[price]" placeholder="enter price"  class="form-control" required/>
        <div class="invalid-feedback">please enter valid price</div>
  </div>
  <br/>

  <div class="mb-3 col-md-8">
     <label for="country" class="form-lebel">Country</label>
     <input name="listing[country]" placeholder="enter country" type="text" class="form-control" required/>

        <div class="invalid-feedback">please enter the country name</div>

  </div>
   </div>
  <br/>

  <div class="mb-3">
      <label for="location" class="form-lebel">Location</label>
      <input name="listing[location]" placeholder="enter location" type="text" class="form-control" required/>
       <div class="invalid-feedback">please enter the location</div>
  </div>
  <br/>
   
  <button class="btn btn-dark add-btn mt-3 mb-3">Add</button>
  </form>

</div>
</div>