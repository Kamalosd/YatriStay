<% layout("/layouts/boilerplate")  %>
<div class="row">
 <div class="col-8 offset-2 text-center">
  <h3>Listing Details </h3>
 </div>
  <div class="card col-6 offset-3 show-card">
    <img src="<%= listing.image%>" class="card-img-top show-img" alt="listing_image"/>
    <div class="card-body">
      <p class="card-text">
        <b> </b><%= listing.title%></b><br/>
        <%= listing.description %><br/>
        &#8377;<%= listing.price.toLocaleString("en-IN") %><br/>
        <%= listing.location %><br/>
        <%= listing.country %><br/>
      </p>
    </div>
  </div>
  <br/>

  <div class="col-6 offset-3 btns">
    <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark edit-btn me-2">Edit</a>
 
  <!-- a taG dia je req ta jbe ota href a ... -->
  
        <form method="POST"  action="/listings/<%=listing._id%>?_method=DELETE">
    <button class="btn btn-dark ">Delete </button>
   

  </form>
</div>

<div class=" col-6 offset-3 mb-3" >
  <hr/>
  <h4>Leave a review</h4>
  <form>
    <div class="mb-3 mt-3">
       <label for="rating" class="form-label">Rating</label>
       <input type="range" min="1" max="5" id="ratin" name="review[rating]" class="form-range" >
    </div>

    <div class="mb-3 mt-3">
       <label for="comment" class="form-label">Comment</label>
       <textarea name="review[comment] " id="comment" cols="30" rows="5" class="form-control"></textarea>
    </div>
    <button class="btn btn-outline-dark">Submit</button>
  </form>

  
</div>
</div>

<!-- tolocaleStriNG jekono no k strinformata convr kre with comma  -->